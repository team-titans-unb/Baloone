const int IN3 = 13; //motor B -> para frente;
const int IN4 = 14; //motor B -> para trás;

// Função para gerar a interface HTML do controle
String getHTML() {
  String ip = WiFi.softAPIP().toString();
  String html = "<!DOCTYPE html><html><head><meta name=\"viewport\" content=\"width=device-width, initial-scale=1, user-scalable=no\">";
  
  // CSS atualizado (Logo no topo, centralizada e pequena)
  html += "<style>body{background-color:#111;color:white;text-align:center;font-family:Arial,sans-serif;}";
  html += ".btn{background-color:#d32f2f;border:none;color:white;font-size:40px;border-radius:15px;margin:5px;width:80px;height:80px; touch-action: manipulation;}";
  html += ".btn:active{background-color:#9a0007;}";
  html += ".dpad{display:inline-block; margin-top:10px;}";
  html += ".row{display:flex; justify-content:center;}";
  html += ".header{display:flex; flex-direction:column; align-items:center; gap:5px; margin-top:10px; margin-bottom:15px;}";
  html += ".logo{width:45px; height:auto;}</style></head><body>"; // largura discreta mantida
  
  // Cabeçalho com a Logo empilhada em cima do Título
  html += "<div class=\"header\">";
  html += "<img class=\"logo\" alt=\"Titans\" src=\"data:image/png;base64,\">";
  html += "<h2 style=\"margin:0;\">Baloone FPV</h2></div>";
  
  // Puxa o streaming de vídeo da porta 81 (Tamanho responsivo)
  html += "<img src=\"http://" + ip + ":81/stream\" style=\"width:95%; max-width:800px; height:auto; border:4px solid #d32f2f; border-radius:10px;\"><br>";
  
  // Criação dos botões alinhados em formato D-Pad (Cruz)
  html += "<div class=\"dpad\">";
  
  // Linha de cima (Só o botão Frente)
  html += "<div class=\"row\">";
  html += "<button class=\"btn\" ontouchstart=\"fetch('/frente')\" ontouchend=\"fetch('/parar')\" onmousedown=\"fetch('/frente')\" onmouseup=\"fetch('/parar')\">&#8593;</button>";
  html += "</div>";
  
  // Linha de baixo (Esquerda, Trás, Direita)
  html += "<div class=\"row\">";
  html += "<button class=\"btn\" ontouchstart=\"fetch('/esq')\" ontouchend=\"fetch('/parar')\" onmousedown=\"fetch('/esq')\" onmouseup=\"fetch('/parar')\">&#8592;</button>";
  html += "<button class=\"btn\" ontouchstart=\"fetch('/tras')\" ontouchend=\"fetch('/parar')\" onmousedown=\"fetch('/tras')\" onmouseup=\"fetch('/parar')\">&#8595;</button>";
  html += "<button class=\"btn\" ontouchstart=\"fetch('/dir')\" ontouchend=\"fetch('/parar')\" onmousedown=\"fetch('/dir')\" onmouseup=\"fetch('/parar')\">&#8594;</button>";
  html += "</div>";
  
  html += "</div></body></html>";
  return html;
}



